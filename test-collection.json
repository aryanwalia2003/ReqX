{
	"name": "Test Suite",
	"auth": {
		"type": "bearer",
		"token": "{{token}}"
	},
	"requests": [
		{
			"name": "GET (inherits collection bearer auth)",
			"method": "GET",
			"url": "{{base_url}}/get"
		},
		{
			"name": "POST (overrides with apikey in header)",
			"method": "POST",
			"url": "{{base_url}}/post",
			"auth": {
				"type": "apikey",
				"key": "X-API-Key",
				"value": "{{token}}",
				"in": "header"
			},
			"headers": {
				"Content-Type": "application/json"
			},
			"body": "{\"hello\":\"world\"}"
		},
		{
			"name": "GET (explicit no auth)",
			"method": "GET",
			"url": "{{base_url}}/get",
			"auth": { "type": "none" }
		}
	]
}
